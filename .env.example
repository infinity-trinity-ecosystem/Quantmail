# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (default for local development):
#   Leave DATABASE_URL unset; the app uses prisma/dev.db automatically.
# PostgreSQL (production):
DATABASE_URL=postgresql://user:password@localhost:5432/quantmail

# ─── Redis ───────────────────────────────────────────────────────────────────
# Required for distributed rate limiting in production.
# Omit in development to fall back to in-memory rate limiting.
REDIS_URL=redis://localhost:6379

# ─── Auth / SSO ──────────────────────────────────────────────────────────────
# Secret used to sign and verify Master SSO tokens (JWT-style HMAC).
# Must be a long, random string in production.
SSO_SECRET=change-me-in-production

# ─── IoT / Device Proof ──────────────────────────────────────────────────────
# HMAC secret used to verify physical dashboard login device proofs.
DEVICE_PROOF_HMAC_SECRET=change-me-in-production

# ─── Critical Alarm Service ───────────────────────────────────────────────────
# Delay in milliseconds before dispatching a synchronized IoT alarm trigger.
SYNCHRONIZED_TRIGGER_DELAY_MS=1500

# ─── Biometric Liveness Provider ─────────────────────────────────────────────
# Which liveness backend to use: "incode" | "microblink" | "local"
LIVENESS_PROVIDER=local

# Incode Liveness SDK (LIVENESS_PROVIDER=incode)
INCODE_API_KEY=your-incode-api-key
INCODE_API_URL=https://demo-api.incode.com

# Microblink Liveness SDK (LIVENESS_PROVIDER=microblink)
MICROBLINK_API_KEY=your-microblink-api-key

# ─── Email (SendGrid / SES) ───────────────────────────────────────────────────
# SendGrid
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=no-reply@quantmail.io

# AWS SES (alternative to SendGrid)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
SES_FROM_EMAIL=no-reply@quantmail.io

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_API_KEY=change-me-in-production
ADMIN_EMAIL=admin@quantmail.io
